:root {
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  background: #f6efe4;
  color: #2c241e;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
}

button,
input,
select,
textarea {
  font: inherit;
}

button {
  border: 0;
  border-radius: 14px;
  padding: 0.75rem 1rem;
  background: #2f6f73;
  color: white;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  font-weight: 700;
}

button:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

button.ghost {
  background: #efe4d7;
  color: #2c241e;
}

button.danger {
  background: #9c3d3d;
}

.app-shell {
  width: min(1180px, calc(100% - 2rem));
  margin: 0 auto;
  padding: 2rem 0 4rem;
}

.hero {
  border-radius: 32px;
  background: linear-gradient(135deg, #fff8ee, #ead7bf);
  padding: 2rem;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 1.5rem;
  box-shadow: 0 20px 60px rgba(45, 36, 30, 0.12);
}

.eyebrow {
  text-transform: uppercase;
  letter-spacing: 0.18em;
  font-size: 0.78rem;
  font-weight: 800;
  color: #2f6f73;
}

h1 {
  margin: 0;
  font-size: clamp(2.4rem, 7vw, 5rem);
  line-height: 0.95;
}

h2,
h3,
p {
  margin-top: 0;
}

.subtitle {
  max-width: 54rem;
  color: #6f5a4c;
  font-size: 1.05rem;
}

.discord-id-box {
  min-width: min(360px, 100%);
}

.tabs {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
  margin: 1.5rem 0;
}

.tabs button {
  background: #fff8ee;
  color: #3d332b;
  box-shadow: 0 8px 24px rgba(45, 36, 30, 0.08);
}

.tabs button.active {
  background: #2f6f73;
  color: white;
}

.grid {
  display: grid;
  grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
  gap: 1.25rem;
}

.card {
  background: #fffaf2;
  border: 1px solid rgba(61, 51, 43, 0.1);
  border-radius: 28px;
  padding: 1.5rem;
  box-shadow: 0 16px 48px rgba(45, 36, 30, 0.1);
}

.muted-card {
  color: #7d6b5f;
}

.card-title-row,
.actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
}

label {
  display: grid;
  gap: 0.4rem;
  font-weight: 800;
  margin: 1rem 0;
}

label small {
  font-weight: 600;
  color: #7d6b5f;
}

input,
select,
textarea {
  width: 100%;
  border: 1px solid rgba(61, 51, 43, 0.18);
  border-radius: 16px;
  padding: 0.85rem 1rem;
  background: white;
  color: #2c241e;
}

textarea {
  min-height: 96px;
  resize: vertical;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0 1rem;
}

.stat-strip {
  margin: 1rem 0;
  border-radius: 20px;
  padding: 1rem;
  background: #eef5f2;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.summary {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  margin-top: 1rem;
}

.summary.vertical {
  grid-template-columns: 1fr;
}

.summary div {
  background: #f6efe4;
  padding: 1rem;
  border-radius: 18px;
}

.summary span {
  display: block;
  color: #7d6b5f;
  text-transform: capitalize;
}

.summary strong {
  font-size: 1.25rem;
}

.good {
  color: #2f7b4f;
}

.bad {
  color: #a63434;
}

.item-list {
  display: grid;
  gap: 1rem;
  margin-top: 1rem;
}

.item-card,
.request-card {
  background: #fdf3e6;
  border: 1px solid rgba(61, 51, 43, 0.1);
  border-radius: 22px;
  padding: 1rem;
}

.message {
  margin-top: 1rem;
  color: #7d4b2d;
  font-weight: 700;
}

@media (max-width: 860px) {
  .hero,
  .grid {
    grid-template-columns: 1fr;
    display: grid;
  }

  .stats-grid,
  .summary {
    grid-template-columns: 1fr;
  }
}

a {
  color: #2f6f73;
  font-weight: 800;
}

.dashboard-grid {
  grid-template-columns: minmax(0, 0.95fr) minmax(360px, 1.05fr);
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.75rem;
  margin: 1rem 0;
}

.split-panels {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1rem;
  margin-top: 1.25rem;
}

.compact-list {
  gap: 0.65rem;
}

.list-button {
  width: 100%;
  justify-content: flex-start;
  background: #fdf3e6;
  color: #2c241e;
  border: 1px solid rgba(61, 51, 43, 0.1);
  box-shadow: none;
}

.list-button.selected {
  background: #2f6f73;
  color: white;
}

.list-button small {
  margin-left: auto;
  opacity: 0.75;
}

.muted-text {
  color: #7d6b5f;
}

.inline-form {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 0.75rem;
  align-items: center;
}

.compact-inline {
  grid-template-columns: 120px auto;
}

.mini-stat-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 0.75rem;
}

.mini-stat {
  background: #f6efe4;
  border-radius: 18px;
  padding: 1rem;
}

.mini-stat span {
  display: block;
  color: #7d6b5f;
  font-size: 0.85rem;
}

.mini-stat strong {
  font-size: 1.6rem;
}

.pill {
  display: inline-flex;
  align-items: center;
  width: fit-content;
  border-radius: 999px;
  padding: 0.35rem 0.7rem;
  background: #eef5f2;
  color: #2f6f73;
  font-weight: 800;
  margin: 0.2rem 0.2rem 0.2rem 0;
}

.skill-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

@media (max-width: 860px) {
  .quick-grid,
  .split-panels,
  .mini-stat-grid,
  .skill-grid {
    grid-template-columns: 1fr;
  }

  .list-button small {
    margin-left: 0;
    display: block;
    width: 100%;
  }

  .inline-form {
    grid-template-columns: 1fr;
  }
}



/* Loadout Builder polish */
.loadout-builder-card {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.loadout-builder-card h2 {
  margin-bottom: 0;
}

.loadout-builder-card .muted-text {
  margin-top: -0.35rem;
  margin-bottom: 0.35rem;
  max-width: 34rem;
  line-height: 1.55;
}

.loadout-builder-card .summary {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0.85rem;
  margin: 0.15rem 0;
}

.loadout-builder-card .summary > div {
  min-width: 0;
  border-radius: 18px;
  padding: 0.95rem 1rem;
  background: rgba(255, 255, 255, 0.64);
  border: 1px solid rgba(77, 55, 35, 0.08);
  box-shadow: 0 8px 24px rgba(56, 38, 20, 0.04);
}

.loadout-builder-card .summary > div span {
  display: block;
  font-size: 0.76rem;
  opacity: 0.72;
  white-space: nowrap;
}

.loadout-builder-card .summary > div strong {
  display: block;
  margin-top: 0.25rem;
  font-size: 1.08rem;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.loadout-builder-card .actions {
  display: flex;
  gap: 0.65rem;
  align-items: center;
  flex-wrap: wrap;
}

.loadout-builder-card .actions button {
  min-height: 42px;
}

.primary-action {
  justify-content: center;
  box-shadow: 0 12px 28px rgba(47, 111, 115, 0.16);
}

.secondary-action {
  justify-content: center;
  opacity: 0.92;
}

.danger-soft {
  color: #7f2f25 !important;
  background: rgba(150, 64, 45, 0.11) !important;
}

.danger-soft:hover {
  background: rgba(150, 64, 45, 0.18) !important;
}

.loadout-builder-card .item-list > p {
  margin: 0.65rem 0;
  color: rgba(44, 31, 22, 0.72);
}

.loadout-builder-card .request-card {
  border-radius: 18px;
}

.request-card small {
  display: block;
  margin-top: 0.35rem;
  color: rgba(44, 31, 22, 0.65);
  line-height: 1.4;
}

label input,
label select,
label textarea {
  margin-top: 0.35rem;
}

@media (max-width: 640px) {
  .loadout-builder-card .summary {
    grid-template-columns: 1fr;
  }

  .loadout-builder-card .actions button,
  .primary-action,
  .secondary-action {
    width: 100%;
    justify-content: center;
  }
}


/* Shop creation polish */
.shop-grid {
  grid-template-columns: minmax(0, 0.9fr) minmax(360px, 1.1fr);
}

.shop-create-card,
.shop-listings-card {
  grid-column: span 1;
}

.shop-create-card .muted-text {
  margin: 0.25rem 0 0;
  max-width: 38rem;
  line-height: 1.5;
}

.shop-create-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0 1rem;
}

.shop-create-grid .full-span {
  grid-column: 1 / -1;
}

.shop-create-card textarea {
  min-height: 88px;
}

.shop-image-preview {
  margin: 1rem 0;
  border: 1px solid rgba(61, 51, 43, 0.1);
  background: #fdf3e6;
  border-radius: 22px;
  padding: 1rem;
}

.shop-image-preview span {
  display: block;
  color: #7d6b5f;
  font-weight: 800;
  margin-bottom: 0.65rem;
}

.shop-image-preview img {
  width: 100%;
  max-height: 280px;
  object-fit: cover;
  border-radius: 18px;
  display: block;
}

.shop-listing-card {
  display: grid;
  grid-template-columns: 84px minmax(0, 1fr) auto;
  align-items: center;
  gap: 1rem;
}

.shop-listing-card > img {
  width: 84px;
  height: 84px;
  border-radius: 18px;
  object-fit: cover;
  background: #efe4d7;
}

.shop-listing-card h3 {
  margin-bottom: 0.25rem;
}

.shop-listing-card p {
  margin-bottom: 0.35rem;
}

@media (max-width: 860px) {
  .shop-grid,
  .shop-create-grid,
  .shop-listing-card {
    grid-template-columns: 1fr;
  }

  .shop-listing-card > img {
    width: 100%;
    height: 180px;
  }
}

/* Staff shop listing review */

.staff-shop-review-card {
  grid-column: 1 / -1;
}

.shop-review-card {
  display: grid;
  grid-template-columns: 140px minmax(0, 1fr) auto;
  gap: 1rem;
  align-items: start;
}

.shop-review-image {
  width: 140px;
  height: 140px;
  object-fit: cover;
  border-radius: 18px;
  border: 1px solid rgba(61, 51, 43, 0.12);
  background: #f6efe4;
}

@media (max-width: 760px) {
  .shop-review-card {
    grid-template-columns: 1fr;
  }

  .shop-review-image {
    width: 100%;
    height: 220px;
  }
}

/* RP Hub */

.rp-hub-grid {
  grid-template-columns: minmax(0, 1fr) minmax(340px, 0.8fr);
}

.rp-main-panel {
  grid-column: 1 / -1;
}

.rp-scene-card,
.rp-claim-card {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 1rem;
  align-items: start;
}

.rp-scene-card small,
.rp-claim-card small {
  display: block;
  margin-top: 0.35rem;
  color: rgba(44, 31, 22, 0.65);
  line-height: 1.4;
}

@media (max-width: 860px) {
  .rp-hub-grid,
  .rp-scene-card,
  .rp-claim-card {
    grid-template-columns: 1fr;
  }
}

/* Activity Log */

.activity-grid {
  grid-template-columns: minmax(320px, 0.8fr) minmax(0, 1.2fr);
}

.activity-timeline-card {
  min-height: 520px;
}

.activity-list {
  gap: 0.85rem;
}

.activity-card {
  border-left: 5px solid rgba(47, 111, 115, 0.35);
}

.activity-card-header {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  flex-wrap: wrap;
  margin-bottom: 0.5rem;
}

.activity-status {
  font-size: 0.78rem;
  font-weight: 900;
  color: rgba(44, 31, 22, 0.66);
}

.activity-card small {
  display: block;
  margin-top: 0.35rem;
  color: rgba(44, 31, 22, 0.62);
  line-height: 1.4;
}

@media (max-width: 860px) {
  .activity-grid {
    grid-template-columns: 1fr;
  }
}

/* Scrollable timeline / recent post panels */

.activity-timeline-card .activity-list,
.rp-recent-posts-card .scroll-list {
  max-height: 620px;
  overflow-y: auto;
  padding-right: 0.4rem;
}

.activity-timeline-card .activity-list::-webkit-scrollbar,
.rp-recent-posts-card .scroll-list::-webkit-scrollbar {
  width: 10px;
}

.activity-timeline-card .activity-list::-webkit-scrollbar-track,
.rp-recent-posts-card .scroll-list::-webkit-scrollbar-track {
  background: rgba(61, 51, 43, 0.08);
  border-radius: 999px;
}

.activity-timeline-card .activity-list::-webkit-scrollbar-thumb,
.rp-recent-posts-card .scroll-list::-webkit-scrollbar-thumb {
  background: rgba(47, 111, 115, 0.38);
  border-radius: 999px;
}

.activity-timeline-card .activity-list::-webkit-scrollbar-thumb:hover,
.rp-recent-posts-card .scroll-list::-webkit-scrollbar-thumb:hover {
  background: rgba(47, 111, 115, 0.58);
}

/* Skill Catalog v2 */

.skills-catalog-card {
  grid-column: 1 / -1;
}

.skill-toolbar {
  display: grid;
  grid-template-columns: minmax(220px, 1.4fr) minmax(180px, 0.8fr) minmax(180px, 0.8fr);
  gap: 1rem;
  margin: 1rem 0;
}

.skill-results-strip {
  display: flex;
  gap: 0.7rem;
  flex-wrap: wrap;
  margin: 0.85rem 0 1.2rem;
}

.skill-results-strip span {
  border-radius: 999px;
  padding: 0.45rem 0.75rem;
  background: rgba(47, 111, 115, 0.11);
  color: rgba(44, 31, 22, 0.75);
  font-size: 0.86rem;
  font-weight: 800;
}

.skill-tree-list {
  display: grid;
  gap: 1.25rem;
}

.skill-tree-section {
  border-top: 1px solid rgba(61, 51, 43, 0.1);
  padding-top: 1rem;
}

.skill-tree-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 0.85rem;
}

.skill-card-v2 {
  align-content: start;
}

.skill-card-v2.locked,
.skill-card-v2.need-xp {
  opacity: 0.82;
}

.skill-meta-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.65rem;
  margin: 0.8rem 0;
}

.skill-meta-grid div {
  border-radius: 14px;
  padding: 0.75rem;
  background: rgba(255, 255, 255, 0.52);
  border: 1px solid rgba(61, 51, 43, 0.08);
}

.skill-meta-grid span {
  display: block;
  font-size: 0.75rem;
  opacity: 0.68;
}

.skill-meta-grid strong {
  display: block;
  margin-top: 0.2rem;
}

.skill-details {
  border-radius: 16px;
  padding: 0.85rem;
  background: rgba(47, 111, 115, 0.08);
  margin: 0.8rem 0;
}

.skill-details p {
  margin: 0.35rem 0;
}

.skill-request-history {
  margin-top: 1.5rem;
}

@media (max-width: 860px) {
  .skill-toolbar {
    grid-template-columns: 1fr;
  }

  .skill-meta-grid {
    grid-template-columns: 1fr;
  }
}

/* Skill Catalog v2 */

.skills-catalog-card {
  grid-column: 1 / -1;
}

.skill-toolbar {
  display: grid;
  grid-template-columns: minmax(220px, 1.4fr) minmax(180px, 0.8fr) minmax(180px, 0.8fr);
  gap: 1rem;
  margin: 1rem 0;
}

.skill-results-strip {
  display: flex;
  gap: 0.7rem;
  flex-wrap: wrap;
  margin: 0.85rem 0 1.2rem;
}

.skill-results-strip span {
  border-radius: 999px;
  padding: 0.45rem 0.75rem;
  background: rgba(47, 111, 115, 0.11);
  color: rgba(44, 31, 22, 0.75);
  font-size: 0.86rem;
  font-weight: 800;
}

.skill-tree-list {
  display: grid;
  gap: 1.25rem;
}

.skill-tree-section {
  border-top: 1px solid rgba(61, 51, 43, 0.1);
  padding-top: 1rem;
}

.skill-tree-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 0.85rem;
}

.skill-card-v2 {
  align-content: start;
}

.skill-card-v2.locked,
.skill-card-v2.need-xp {
  opacity: 0.82;
}

.skill-meta-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.65rem;
  margin: 0.8rem 0;
}

.skill-meta-grid div {
  border-radius: 14px;
  padding: 0.75rem;
  background: rgba(255, 255, 255, 0.52);
  border: 1px solid rgba(61, 51, 43, 0.08);
}

.skill-meta-grid span {
  display: block;
  font-size: 0.75rem;
  opacity: 0.68;
}

.skill-meta-grid strong {
  display: block;
  margin-top: 0.2rem;
}

.skill-details {
  border-radius: 16px;
  padding: 0.85rem;
  background: rgba(47, 111, 115, 0.08);
  margin: 0.8rem 0;
}

.skill-details p {
  margin: 0.35rem 0;
}

.skill-request-history {
  margin-top: 1.5rem;
}

@media (max-width: 860px) {
  .skill-toolbar {
    grid-template-columns: 1fr;
  }

  .skill-meta-grid {
    grid-template-columns: 1fr;
  }
}

/* OC owned skills panel */

.oc-dashboard-grid {
  grid-template-columns: minmax(320px, 0.95fr) minmax(360px, 1.15fr);
}

.oc-skills-card {
  min-height: 420px;
}

.owned-skill-group {
  margin-top: 1rem;
  border-top: 1px solid rgba(61, 51, 43, 0.1);
  padding-top: 0.85rem;
}

.owned-skill-group-heading {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  margin-bottom: 0.65rem;
}

.owned-skill-group-heading h3 {
  margin: 0;
}

.owned-skill-group-heading span {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 2rem;
  min-height: 2rem;
  border-radius: 999px;
  background: rgba(47, 111, 115, 0.12);
  font-weight: 900;
  color: #2f6f73;
}

.owned-skill-list {
  display: grid;
  gap: 0.55rem;
}

.owned-skill-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 1rem;
  align-items: center;
  border-radius: 18px;
  padding: 0.8rem 0.9rem;
  background: rgba(255, 255, 255, 0.58);
  border: 1px solid rgba(61, 51, 43, 0.08);
}

.owned-skill-row.pending {
  background: rgba(245, 198, 93, 0.14);
}

.owned-skill-row strong,
.owned-skill-row small {
  display: block;
}

.owned-skill-row small {
  margin-top: 0.2rem;
  color: rgba(44, 31, 22, 0.58);
  overflow-wrap: anywhere;
}

.owned-skill-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.2rem;
  font-size: 0.82rem;
  color: rgba(44, 31, 22, 0.66);
  font-weight: 800;
  white-space: nowrap;
}

.oc-pending-skills {
  margin-top: 1.25rem;
}

@media (max-width: 980px) {
  .oc-dashboard-grid {
    grid-template-columns: 1fr;
  }

  .owned-skill-row {
    grid-template-columns: 1fr;
  }

  .owned-skill-meta {
    align-items: flex-start;
  }
}

/* Staff skill review cards v2 */

.staff-dashboard-v2 {
  display: grid;
  gap: 1.1rem;
}

.staff-overview-card,
.staff-section-card {
  grid-column: 1 / -1;
}

.staff-queue-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 0.65rem;
  margin-top: 1rem;
}

.staff-queue-tabs button {
  display: inline-flex;
  align-items: center;
  gap: 0.55rem;
  border: 0;
  border-radius: 16px;
  padding: 0.8rem 1rem;
  font-weight: 900;
  background: rgba(255, 255, 255, 0.62);
  color: #2c1f16;
  cursor: pointer;
}

.staff-queue-tabs button.active {
  background: #2f6f73;
  color: white;
}

.staff-queue-tabs button span {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 1.6rem;
  min-height: 1.6rem;
  border-radius: 999px;
  background: rgba(0, 0, 0, 0.1);
}

.skill-review-list {
  margin-top: 1rem;
}

.skill-review-card-v2 {
  border-left: 5px solid rgba(156, 61, 61, 0.5);
}

.skill-review-card-v2.safe {
  border-left-color: rgba(47, 143, 91, 0.65);
}

.skill-review-header {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: flex-start;
}

.skill-review-eyebrow {
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem;
  margin-bottom: 0.45rem;
}

.skill-review-eyebrow span {
  border-radius: 999px;
  padding: 0.35rem 0.55rem;
  background: rgba(47, 111, 115, 0.11);
  color: rgba(44, 31, 22, 0.72);
  font-size: 0.75rem;
  font-weight: 900;
}

.review-check-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 0.55rem;
  margin: 0.85rem 0;
}

.review-check-pill {
  border-radius: 14px;
  padding: 0.65rem 0.7rem;
  font-size: 0.78rem;
  font-weight: 900;
  background: rgba(255, 255, 255, 0.6);
  border: 1px solid rgba(61, 51, 43, 0.08);
}

.review-check-pill.good {
  color: #2f6f5b;
}

.review-check-pill.bad {
  color: #9c3d3d;
}

.skill-review-detail-box {
  border-radius: 16px;
  padding: 0.75rem 0.85rem;
  background: rgba(255, 255, 255, 0.52);
  border: 1px solid rgba(61, 51, 43, 0.08);
  margin-top: 0.65rem;
}

.skill-review-detail-box strong {
  display: block;
  margin-bottom: 0.25rem;
}

.skill-review-detail-box p {
  margin: 0;
}

.skill-review-warning {
  margin-top: 0.65rem;
  border-radius: 16px;
  padding: 0.75rem 0.85rem;
  background: rgba(156, 61, 61, 0.12);
  color: #7e2d2d;
  font-weight: 900;
}

@media (max-width: 900px) {
  .skill-review-header {
    flex-direction: column;
  }

  .review-check-grid {
    grid-template-columns: 1fr;
  }
}

/* Activity page v1 */

.activity-page-v1 {
  display: grid;
  gap: 1.1rem;
}

.activity-hero-card {
  grid-column: 1 / -1;
}

.activity-filter-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 0.65rem;
  margin-top: 1rem;
}

.activity-filter-tabs button {
  display: inline-flex;
  align-items: center;
  gap: 0.55rem;
  border: 0;
  border-radius: 16px;
  padding: 0.8rem 1rem;
  font-weight: 900;
  background: rgba(255, 255, 255, 0.62);
  color: #2c1f16;
  cursor: pointer;
}

.activity-filter-tabs button.active {
  background: #2f6f73;
  color: white;
}

.activity-filter-tabs button span {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 1.6rem;
  min-height: 1.6rem;
  border-radius: 999px;
  background: rgba(0, 0, 0, 0.1);
}

.activity-timeline {
  display: grid;
  gap: 0.9rem;
  position: relative;
}

.activity-card {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  gap: 0.8rem;
  align-items: start;
}

.activity-marker {
  width: 2.35rem;
  height: 2.35rem;
  display: inline-grid;
  place-items: center;
  border-radius: 999px;
  background: #fff8ef;
  border: 1px solid rgba(61, 51, 43, 0.1);
  box-shadow: 0 8px 20px rgba(44, 31, 22, 0.08);
}

.activity-content {
  border-radius: 22px;
  padding: 1rem;
  background: rgba(255, 255, 255, 0.72);
  border: 1px solid rgba(61, 51, 43, 0.1);
  box-shadow: 0 12px 30px rgba(44, 31, 22, 0.08);
}

.activity-card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 1rem;
}

.activity-type-label {
  display: inline-block;
  font-size: 0.72rem;
  font-weight: 900;
  letter-spacing: 0.06em;
  color: rgba(44, 31, 22, 0.58);
  margin-bottom: 0.25rem;
}

.activity-card h3 {
  margin: 0;
}

.activity-time {
  color: rgba(44, 31, 22, 0.58);
  font-size: 0.88rem;
  margin-top: 0.35rem;
}

.activity-note {
  border-radius: 16px;
  padding: 0.75rem 0.85rem;
  background: rgba(47, 111, 115, 0.08);
  margin-top: 0.65rem;
}

.activity-note.staff {
  background: rgba(245, 198, 93, 0.14);
}

.activity-note strong {
  display: block;
  margin-bottom: 0.25rem;
}

.activity-note p {
  margin: 0;
}

.activity-content small {
  display: block;
  margin-top: 0.75rem;
  color: rgba(44, 31, 22, 0.55);
}

@media (max-width: 760px) {
  .activity-card-header {
    flex-direction: column;
  }

  .activity-card {
    grid-template-columns: 1fr;
  }

  .activity-marker {
    display: none;
  }
}

/* Activity date filters */

.activity-date-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 0.8rem;
  align-items: end;
  margin-top: 1rem;
  padding-top: 1rem;
  border-top: 1px solid rgba(61, 51, 43, 0.1);
}

.activity-date-filters label {
  min-width: 180px;
  flex: 0 1 220px;
}

.activity-date-filters button {
  min-height: 2.8rem;
}

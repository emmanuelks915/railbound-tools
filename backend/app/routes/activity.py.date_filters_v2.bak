from __future__ import annotations

from datetime import datetime, timezone
from typing import Any

from fastapi import APIRouter, Depends, Query

from app.security import actor_from_header, require_staff
from app.services import get_guild_id, sb_data
from app.supabase_client import get_supabase

router = APIRouter(prefix="/api/activity", tags=["activity"])


def _as_list(value: Any) -> list[dict[str, Any]]:
    rows = sb_data(value) or []
    return rows if isinstance(rows, list) else []


def _timestamp(row: dict[str, Any]) -> str:
    for key in ("created_at", "reviewed_at", "approved_at", "updated_at", "timestamp"):
        value = row.get(key)
        if value:
            return str(value)

    return datetime.now(timezone.utc).isoformat()


def _safe_rows(sb, table: str, *, limit: int, order_by: str = "created_at") -> list[dict[str, Any]]:
    try:
        return _as_list(
            sb.table(table)
            .select("*")
            .eq("guild_id", get_guild_id())
            .order(order_by, desc=True)
            .limit(limit)
            .execute()
        )
    except Exception:
        try:
            return _as_list(
                sb.table(table)
                .select("*")
                .eq("guild_id", get_guild_id())
                .limit(limit)
                .execute()
            )
        except Exception:
            return []


def _character_lookup(sb, character_ids: set[str]) -> dict[str, dict[str, Any]]:
    if not character_ids:
        return {}

    try:
        rows = _as_list(
            sb.table("characters")
            .select("character_id,name,user_id")
            .eq("guild_id", get_guild_id())
            .in_("character_id", list(character_ids))
            .execute()
        )
    except Exception:
        return {}

    return {str(row.get("character_id")): row for row in rows if row.get("character_id")}


def _skill_lookup(sb, skill_keys: set[str]) -> dict[str, dict[str, Any]]:
    if not skill_keys:
        return {}

    try:
        rows = _as_list(
            sb.table("skill_definitions")
            .select("skill_key,name,tree,tier,cost")
            .eq("guild_id", get_guild_id())
            .in_("skill_key", list(skill_keys))
            .execute()
        )
    except Exception:
        return {}

    return {str(row.get("skill_key")): row for row in rows if row.get("skill_key")}


def _event(
    *,
    event_type: str,
    title: str,
    status: str | None,
    timestamp: str,
    actor_id: Any = None,
    staff_id: Any = None,
    character: dict[str, Any] | None = None,
    details: dict[str, Any] | None = None,
    raw: dict[str, Any] | None = None,
) -> dict[str, Any]:
    return {
        "type": event_type,
        "title": title,
        "status": status,
        "timestamp": timestamp,
        "actor_id": actor_id,
        "staff_id": staff_id,
        "character": character,
        "details": details or {},
        "raw": raw or {},
    }


@router.get("/recent")
def recent_activity(
    activity_type: str = Query(default="all", alias="type"),
    limit: int = Query(default=100, ge=1, le=250),
    actor_discord_id: int | None = Depends(actor_from_header),
):
    require_staff(actor_discord_id)

    sb = get_supabase()

    want_all = activity_type == "all"
    events: list[dict[str, Any]] = []

    stat_rows = _safe_rows(sb, "stat_upgrade_requests", limit=limit) if want_all or activity_type == "stats" else []
    skill_rows = _safe_rows(sb, "skill_purchase_requests", limit=limit) if want_all or activity_type == "skills" else []
    shop_rows = _safe_rows(sb, "shop_items", limit=limit) if want_all or activity_type == "shops" else []

    xp_rows: list[dict[str, Any]] = []
    if want_all or activity_type == "xp":
        xp_rows = _safe_rows(sb, "oc_xp_transactions", limit=limit)
        if not xp_rows:
            xp_rows = _safe_rows(sb, "character_xp_transactions", limit=limit)
        if not xp_rows:
            xp_rows = _safe_rows(sb, "xp_transactions", limit=limit)

    character_ids: set[str] = set()

    for row in stat_rows + skill_rows:
        if row.get("character_id"):
            character_ids.add(str(row.get("character_id")))

    for row in xp_rows:
        if row.get("character_id"):
            character_ids.add(str(row.get("character_id")))

    character_map = _character_lookup(sb, character_ids)
    skill_map = _skill_lookup(sb, {str(row.get("skill_key")) for row in skill_rows if row.get("skill_key")})

    for row in stat_rows:
        character = character_map.get(str(row.get("character_id")))
        total_cost = row.get("total_cost") or row.get("cost") or 0
        status = str(row.get("status") or "unknown")

        events.append(
            _event(
                event_type="stats",
                title=f"Stat request • {character.get('name') if character else 'Unknown OC'}",
                status=status,
                timestamp=_timestamp(row),
                actor_id=row.get("requested_by_discord_id"),
                staff_id=row.get("staff_discord_id") or row.get("reviewed_by_discord_id"),
                character=character,
                details={
                    "cost": total_cost,
                    "note": row.get("submitter_note"),
                    "staff_note": row.get("staff_note") or row.get("denial_reason"),
                    "request_id": row.get("request_id"),
                },
                raw=row,
            )
        )

    for row in skill_rows:
        character = character_map.get(str(row.get("character_id")))
        skill = skill_map.get(str(row.get("skill_key")))
        skill_name = skill.get("name") if skill else row.get("skill_key")
        status = str(row.get("status") or "unknown")

        events.append(
            _event(
                event_type="skills",
                title=f"Skill request • {skill_name}",
                status=status,
                timestamp=_timestamp(row),
                actor_id=row.get("requested_by_discord_id"),
                staff_id=row.get("staff_discord_id") or row.get("reviewed_by_discord_id"),
                character=character,
                details={
                    "skill_key": row.get("skill_key"),
                    "skill": skill,
                    "cost": row.get("cost") or (skill or {}).get("cost"),
                    "note": row.get("submitter_note"),
                    "staff_note": row.get("staff_note") or row.get("denial_reason"),
                    "request_id": row.get("request_id"),
                },
                raw=row,
            )
        )

    for row in shop_rows:
        status = str(row.get("review_status") or row.get("status") or ("active" if row.get("is_active") else "unknown"))
        events.append(
            _event(
                event_type="shops",
                title=f"Shop listing • {row.get('name') or 'Unnamed item'}",
                status=status,
                timestamp=_timestamp(row),
                actor_id=row.get("created_by_discord_id") or row.get("submitted_by_discord_id"),
                staff_id=row.get("reviewed_by_discord_id") or row.get("approved_by"),
                details={
                    "item_id": row.get("item_id"),
                    "price": row.get("price"),
                    "stock": row.get("stock"),
                    "item_type": row.get("item_type"),
                    "item_class": row.get("item_class"),
                    "note": row.get("submitter_note"),
                    "staff_note": row.get("staff_note") or row.get("denial_reason"),
                },
                raw=row,
            )
        )

    for row in xp_rows:
        character = character_map.get(str(row.get("character_id")))
        amount = row.get("amount") or row.get("xp_delta") or row.get("delta") or 0
        tx_type = row.get("tx_type") or row.get("transaction_type") or row.get("kind") or "XP"

        events.append(
            _event(
                event_type="xp",
                title=f"XP {tx_type} • {character.get('name') if character else 'Unknown OC'}",
                status=str(tx_type),
                timestamp=_timestamp(row),
                actor_id=row.get("actor_discord_id") or row.get("created_by_discord_id"),
                character=character,
                details={
                    "amount": amount,
                    "reason": row.get("reason") or row.get("note"),
                    "reference_type": row.get("reference_type"),
                    "reference_id": row.get("reference_id"),
                },
                raw=row,
            )
        )

    def sort_key(event: dict[str, Any]) -> str:
        return str(event.get("timestamp") or "")

    events.sort(key=sort_key, reverse=True)

    return {
        "events": events[:limit],
        "count": len(events[:limit]),
        "sources": {
            "stats": len(stat_rows),
            "skills": len(skill_rows),
            "shops": len(shop_rows),
            "xp": len(xp_rows),
        },
    }
